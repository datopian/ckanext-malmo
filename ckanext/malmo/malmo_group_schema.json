{
  "group_type": "group",
  "about_url": "http://github.com/ckan/ckanext-scheming",
  "fields": [
    {
      "field_name": "title",
      "label": "Name",
      "validators": "ignore_missing unicode_safe",
      "form_snippet": "large_text.html",
      "form_attrs": { "data-module": "slug-preview-target" },
      "form_placeholder": "My theme"
    },
    {
      "field_name": "title_translated",
      "label": "Name (translated)",
      "validators": "ignore_missing unicode_safe",
      "form_snippet": "hidden.html"
    },
    {
      "field_name": "display_name",
      "label": "Display Name",
      "validators": "ignore_missing unicode_safe",
      "form_snippet": "hidden.html"
    },
    {
      "field_name": "display_name_translated",
      "label": "Display Name (translated)",
      "validators": "ignore_missing unicode_safe",
      "form_snippet": "hidden.html"
    },
    {
      "field_name": "name",
      "label": "URL",
      "validators": "not_empty unicode_safe name_validator group_name_validator",
      "form_snippet": "slug.html",
      "form_placeholder": "my-theme"
    },
    {
      "field_name": "description",
      "label": "Description",
      "form_snippet": "markdown.html",
      "form_placeholder": "A little information about my group..."
    },
    {
      "field_name": "description_translated",
      "label": "Description (translated)",
      "form_snippet": "hidden.html"
    },
    {
      "field_name": "url",
      "label": "Image URL",
      "form_placeholder": "http://example.com/my-image.jpg"
    }
  ]
}
